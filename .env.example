# Copy to .env and fill in to bake your Basecamp OAuth app credentials into the
# release build (see README "Building a release"). The .env file is gitignored.
#
# Register an app at https://launchpad.37signals.com/integrations with redirect
# URI http://127.0.0.1:8976/callback
#
# NOTE: 37signals Launchpad does not support PKCE and treats the secret as a
# confidential-client credential. A secret shipped in a distributed build is
# effectively public — rotate it if leaked. Users can also supply their own app
# via the plugin's advanced clientId/clientSecret/redirectUri config fields.
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
