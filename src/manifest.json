{
  "id": "basecamp-issue-provider",
  "name": "Basecamp",
  "version": "0.1.0",
  "manifestVersion": 1,
  "minSupVersion": "13.0.0",
  "description": "Basecamp issue provider plugin",
  "author": "Super Productivity",
  "type": "issueProvider",
  "icon": "icon.svg",
  "iFrame": false,
  "permissions": [],
  "hooks": [
    "currentTaskChange",
    "taskComplete"
  ],
  "i18n": {
    "languages": [
      "en"
    ]
  },
  "issueProvider": {
    "pollIntervalMs": 600000,
    "humanReadableName": "Basecamp",
    "issueStrings": {
      "singular": "To-do",
      "plural": "To-dos"
    }
  }
}
